+NET_SOCKET_OFFLOAD_REGISTER(wolfip, CONFIG_NET_SOCKETS_OFFLOAD_PRIORITY,
+			    NET_AF_INET, wolfip_is_supported_family,
+			    wolfip_socket_create);
