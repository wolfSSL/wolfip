+int wolfip_ctrl_get_addr(unsigned int if_idx, ip4 *ip, ip4 *mask, ip4 *gw)
+{
+	struct wolfIP *s;
+
+	if (if_idx >= CONFIG_WOLFIP_MAX_INTERFACES) {
+		return -EINVAL;
+	}
+
+	if (ip == NULL || mask == NULL || gw == NULL) {
+		return -EINVAL;
+	}
+
+	wolfip_zephyr_lock();
+	s = wolfip_zephyr_get_stack();
+	if (s == NULL) {
+		wolfip_zephyr_unlock();
+		return -ENODEV;
+	}
+
+	wolfIP_ipconfig_get_ex(s, if_idx, ip, mask, gw);
+	wolfip_zephyr_unlock();
+	return 0;
+}
