@@ -64,7 +71,12 @@ static int cmd_net_arp(const struct shell *sh, size_t argc, char *argv[])
 			PR("ARP cache is empty.\n");
 		}
 	}
+#elif defined(CONFIG_WOLFIP)
+	ARG_UNUSED(argv);
